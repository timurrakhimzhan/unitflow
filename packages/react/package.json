{
  "name": "@unitflow/react",
  "version": "0.2.0",
  "type": "module",
  "description": "React bindings for Unitflow.",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timurrakhimzhan/unitflow.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/timurrakhimzhan/unitflow/issues"
  },
  "homepage": "https://github.com/timurrakhimzhan/unitflow#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "tsc -p tsconfig.test.json && vitest run"
  },
  "dependencies": {
    "@unitflow/core": "workspace:^"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.88",
    "react": ">=18"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.88",
    "@types/react": "*",
    "effect": "4.0.0-beta.88",
    "react": "*",
    "vitest": "3.2.4"
  }
}
