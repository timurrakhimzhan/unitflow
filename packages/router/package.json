{
  "name": "@unitflow/router",
  "version": "0.5.1",
  "type": "module",
  "description": "Effect-native, Unitflow-aware typed router with React bindings.",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "default": "./dist/router.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "tsc -p tsconfig.test.json && vitest run"
  },
  "dependencies": {
    "@unitflow/core": "workspace:^",
    "@unitflow/react": "workspace:^"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.88",
    "react": ">=18"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.88",
    "@types/react": "*",
    "effect": "4.0.0-beta.88",
    "react": "*",
    "vitest": "3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
